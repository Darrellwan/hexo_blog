.content {
  padding-top: 40px;
}

.post-body {
  +desktop() {
    text-align: unquote(hexo-config('text_align.desktop'));
  }

  +tablet-mobile() {
    text-align: unquote(hexo-config('text_align.mobile'));
  }

  h1, h2, h3, h4, h5, h6 {
    color: $orange-main;
    padding-top: 10px;
    cursor: pointer;

    .header-anchor {
      border-bottom-style: none;
      color: $orange-main;
      margin-right: 8px;
      opacity: 0;
      transition: opacity 0.15s, color 0.15s;
      font-size: 0.8em;
      vertical-align: middle;

      &:hover {
        color: inherit;
      }

      &.copied {
        color: #4caf50;
      }
    }

    &:hover .header-anchor {
      opacity: 1;
    }
  }

  iframe, img, video {
    margin-bottom: 20px;
  }

  .video-container {
    height: 0;
    margin-bottom: 20px;
    overflow: hidden;
    padding-top: 75%;
    position: relative;
    width: 100%;

    iframe, object, embed {
      height: 100%;
      left: 0;
      margin: 0;
      position: absolute;
      top: 0;
      width: 100%;
    }
  }
  h2, h2 a {
    color: $orange-sub;
  }
}

